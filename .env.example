# Database
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# Better Auth
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# AES-256-GCM master key for encrypting stored SMTP passwords
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_MASTER_KEY=

# Dedicated SMTP for magic-link login emails (separate from user-saved providers)
MAGIC_LINK_SMTP_HOST=smtp.gmail.com
MAGIC_LINK_SMTP_PORT=587
MAGIC_LINK_SMTP_USER=
MAGIC_LINK_SMTP_PASS=
MAGIC_LINK_FROM=
